{
  "name": "horus-spec-driven",
  "version": "3.0.0",
  "description": "Horus Spec Driven — multi-CLI wrapper around @opengsd/gsd-core with role-based unified commands (67→17) and horus-sdk-adapter. Supports Hermes, Claude Code, Codex, Gemini CLI, and GitHub Copilot.",
  "bin": {
    "hsd": "bin/install.js"
  },
  "scripts": {
    "detect": "node bin/install.js detect",
    "wordlist": "node bin/install.js wordlist",
    "install": "node bin/install.js install --all --global",
    "sync": "node bin/install.js sync",
    "unified": "node bin/rebrand.js modules/unified-wordlist.json && node bin/build-unified-skills.cjs",
    "install:hermes": "node bin/install.js install --runtime=hermes --global",
    "install:claude": "node bin/install.js install --runtime=claude --global",
    "install:codex": "node bin/install.js install --runtime=codex --global",
    "install:gemini": "node bin/install.js install --runtime=gemini --global",
    "install:copilot": "node bin/install.js install --runtime=copilot --local"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "runtimes",
    "docs",
    "horus-spec-driven.json",
    "README.md",
    "SETUP.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "hsd",
    "horus-spec-driven",
    "gsd-core",
    "opengsd",
    "spec-driven",
    "hermes",
    "claude-code",
    "codex",
    "gemini-cli",
    "github-copilot",
    "multi-runtime",
    "slash-commands",
    "spec-driven-development",
    "context-engineering",
    "knowledge-graph"
  ],
  "author": "Giovanni Muniz <munizgiovanni@hotmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giovannimnz/horus-spec-driven.git"
  },
  "bugs": {
    "url": "https://github.com/giovannimnz/horus-spec-driven/issues"
  },
  "homepage": "https://github.com/giovannimnz/horus-spec-driven"
}
