        "color": "#ea580c",
        "description": "Build Logic — debug, maintain, context"
      },
      "qa": {
        "name": "QA",
        "color": "#dc2626",
        "description": "Verify — validate, audit, review"
      }
    }
  },
  "branding": {
    "project": "Horus Spec Driven",
